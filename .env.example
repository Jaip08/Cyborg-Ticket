# Copy the relevant blocks into the right place:
#  - backend values  -> environment variables / backend/src/TicketSystem.Api/appsettings.json
#  - frontend values -> frontend/.env.local

# ---- Backend (ASP.NET Core) ----
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ticketsystem;Username=postgres;Password=postgres
Jwt__Key=replace-with-a-long-random-secret-at-least-32-characters
Jwt__Issuer=TicketSystem
Jwt__Audience=TicketSystemClient
Jwt__ExpiryMinutes=120
Cors__AllowedOrigins__0=http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:5080/api
